# Postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/csvapp

# Session / JWT
SECRET_KEY=change-me-to-a-long-random-string

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (Azure portal > App registrations)
# Redirect URI: http://localhost:8000/auth/callback/microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# Apple Sign In (Apple Developer > Certificates, Identifiers & Profiles)
# Redirect URI: http://localhost:8000/auth/callback/apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=/app/secrets/apple_key.p8

# OAuth redirect + frontend
OAUTH_REDIRECT_BASE=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Cleanup
CLEANUP_INTERVAL_MINUTES=60
DELETE_AFTER_DAYS=2
