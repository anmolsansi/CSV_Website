# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-use-a-strong-password
POSTGRES_DB=csvapp
DATABASE_URL=postgresql+psycopg2://postgres:changeme-use-a-strong-password@db:5432/csvapp

# Application
ENVIRONMENT=production
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# Frontend URL (public-facing)
FRONTEND_URL=https://yourdomain.com
OAUTH_REDIRECT_BASE=https://yourdomain.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=/app/secrets/apple_key.p8

# Cleanup
CLEANUP_INTERVAL_MINUTES=60
DELETE_AFTER_DAYS=2

# Testing (keep false in production)
TEST_AUTH=false
